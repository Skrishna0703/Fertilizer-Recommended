import time
import os
import joblib
import numpy as np

# ============================================================================
# PAGE CONFIGURATION
# ============================================================================

st.set_page_config(
    page_title="Fertilizer Recommendation",
    page_icon="🌾",
    layout="wide",
    initial_sidebar_state="expanded"
)

