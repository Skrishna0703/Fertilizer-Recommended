# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

def render_custom_css():
    """Render custom CSS styling."""
    st.markdown(custom_css, unsafe_allow_html=True)


def load_ml_models():
    """Load trained ML models and encoders."""
    try:
        model = joblib.load('fertilizer_model.pkl')
        crop_encoder = joblib.load('crop_encoder.pkl')
        fertilizer_encoder = joblib.load('fertilizer_encoder.pkl')
        scaler = joblib.load('scaler.pkl')
        return model, crop_encoder, fertilizer_encoder, scaler
    except FileNotFoundError:
        return None, None, None, None


def predict_fertilizer(N, P, K, pH, crop, model, crop_encoder, fertilizer_encoder, scaler):
    """Make fertilizer prediction."""
    try:
        if model is None:
            return "NPK Balanced Fertilizer", 75
        
        crop_encoded = crop_encoder.transform([crop])[0]
        features = np.array([[N, P, K, pH, crop_encoded]])
        features_scaled = scaler.transform(features)
        prediction = model.predict(features_scaled)[0]
        fertilizer = fertilizer_encoder.inverse_transform([prediction])[0]
        
        # Calculate confidence
        confidence = min(95, 70 + int((N + P + K) / 10))
        
        return fertilizer, confidence
    except Exception as e:
        return "NPK Balanced Fertilizer", 75


def display_ready_state():
    """Display the ready-for-analysis state."""
    st.markdown(
        "<div class='emoji-circle'>🧪</div>",
        unsafe_allow_html=True
    )
    
    st.markdown(
        "<p class='result-title'>Ready for Analysis</p>",
        unsafe_allow_html=True
    )
    
    st.markdown(
        "<p class='result-description'>"
        "Enter your soil NPK values to get personalized fertilizer recommendations"
        "</p>",
        unsafe_allow_html=True
    )


def display_recommendation(fertilizer_type, confidence=85):
    """
    Display simple fertilizer recommendation information.
    
    Parameters:
    -----------
    fertilizer_type : str
        Recommended fertilizer type
    confidence : float
        Confidence percentage
    """
    # Fertilizer information for users
    fertilizer_info = {
        "Urea": {
            "description": "High Nitrogen content fertilizer",
            "benefits": "Best for leaf growth and plant greening. Use when soil nitrogen is low.",
            "usage": "Apply 200-300 kg per hectare"
        },
        "DAP": {
            "description": "Di-Ammonium Phosphate - Nitrogen & Phosphorus rich",
            "benefits": "Promotes root development and early growth. Good for seed germination.",
            "usage": "Apply 150-200 kg per hectare"
        },
        "NPK Balanced": {
            "description": "Balanced fertilizer with Nitrogen, Phosphorus, and Potassium",
            "benefits": "Promotes overall plant growth and health. Balanced nutrients for all crops.",
            "usage": "Apply 250-350 kg per hectare"
        },
        "SSP": {
            "description": "Single Super Phosphate - High Phosphorus content",
            "benefits": "Strengthens roots and flower development. Good for deficient soils.",
            "usage": "Apply 100-150 kg per hectare"
        }
    }
    
    # Get fertilizer information
    info = fertilizer_info.get(fertilizer_type, {
        "description": "Recommended Fertilizer",
        "benefits": "Suitable for your soil conditions",
        "usage": "Follow recommended application rates"
    })
    
    # Display title
    st.markdown("### ✓ Recommended Fertilizer")
    
    # Display fertilizer name in large text
    st.markdown(f"## {fertilizer_type}")
    
    # Display information in columns for better readability
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("**What is it?**")
        st.write(info["description"])
        
        st.markdown("**How to use:**")
        st.write(info["usage"])
    
    with col2:
        st.markdown("**Benefits for your soil:**")
        st.write(info["benefits"])
        
        st.markdown("**Confidence Score:**")
        st.success(f"{confidence}%")
    
    st.divider()


# ============================================================================
# SIDEBAR
# ============================================================================

def render_sidebar():
    """Render sidebar with information and settings."""
    with st.sidebar:
        st.markdown("""
        <style>
        [data-testid="stMarkdownContainer"] h3 {
            background-color: #1a1a1a !important;
            color: white !important;
            padding: 0.8rem 1rem !important;
            border-radius: 6px !important;
            margin-bottom: 1rem !important;
        }
        
        [data-testid="stMarkdownContainer"] ul {
            background-color: transparent !important;
        }
        
        [data-testid="stMarkdownContainer"] li {
            color: #ffffff !important;
            margin-bottom: 0.5rem !important;
        }
        
        [data-testid="stMarkdownContainer"] strong {
            color: #ffffff !important;
            font-weight: 700 !important;
        }
        
        [data-testid="stMarkdownContainer"] p {
            color: #ffffff !important;
        }
        </style>
        """, unsafe_allow_html=True)
        
        st.markdown("### 📊 Dashboard Settings")
        
        st.markdown("---")
        
        st.markdown("### 📖 About")
        st.markdown(
            """
This tool helps farmers and agricultural professionals get personalized 
fertilizer recommendations based on their soil analysis.

**Key Features:**
- Real-time recommendations
- Based on NPK levels and pH
- Easy-to-use interface
- Instant results

**How to Use:**
1. Enter your soil parameters
2. Click "Analyze & Recommend"
3. Get customized fertilizer suggestions
            """
        )
        
        st.markdown("---")
        
        st.markdown("### ℹ️ Information")
        st.markdown(
            """
**N (Nitrogen):** Essential for leaf growth  
**P (Phosphorus):** Important for root development  
**K (Potassium):** Improves plant strength  
**pH:** Soil acidity/alkalinity level
            """
        )


# ============================================================================
# MAIN UI LAYOUT
# ============================================================================

def main():
    """Main application function."""
    
    # Apply custom CSS
    render_custom_css()
    
    # Render sidebar
    render_sidebar()
    
    # Load models once
    model, crop_encoder, fertilizer_encoder, scaler = load_ml_models()
    
    # Get available crops
    if crop_encoder is not None:
        available_crops = list(crop_encoder.classes_)
    else:
        available_crops = ["Rice", "Wheat", "Maize", "Cotton", "Pulses", "Sugarcane", 
                          "Barley", "Soybean", "Groundnut", "Chickpea", "Tobacco", "Oats"]
    
    # Main Title and Subtitle
    st.markdown(
        "<h1 class='main-title'>🌾 Precision Nutrient Management</h1>",
        unsafe_allow_html=True
    )
    
    st.markdown(
        "<p class='subtitle'>"
        "Get customized fertilizer recommendations based on your soil's NPK levels and pH"
        "</p>",
        unsafe_allow_html=True
    )
    
    st.divider()
    
    # Two-Column Layout
    col_input, col_result = st.columns([1, 1.4], gap="large")
    
    # ========================================================================
    # LEFT COLUMN - INPUT FORM
    # ========================================================================
    
    with col_input:
        st.markdown(
            "<div class='section-title'>🧪 Soil Analysis Input</div>",
            unsafe_allow_html=True
        )
        
        # Create input card container
        with st.container():
            
            # Nitrogen Input
            st.markdown("<label class='input-label'>Nitrogen (N) - ppm</label>", 
                       unsafe_allow_html=True)
            nitrogen = st.number_input(
                "Nitrogen",
                min_value=0,
                max_value=500,
                value=280,
                step=1,
                label_visibility="collapsed",
                key="nitrogen_input"
            )
            st.markdown(
                "<span class='helper-text'>Available nitrogen in soil</span>",
                unsafe_allow_html=True
            )
            
            # Phosphorus Input
            st.markdown("<label class='input-label'>Phosphorus (P) - ppm</label>", 
                       unsafe_allow_html=True)
            phosphorus = st.number_input(
                "Phosphorus",
                min_value=0,
                max_value=200,
                value=45,
                step=1,
                label_visibility="collapsed",
                key="phosphorus_input"
            )
            st.markdown(
                "<span class='helper-text'>Available phosphorus in soil</span>",
                unsafe_allow_html=True
            )
            
            # Potassium Input
            st.markdown("<label class='input-label'>Potassium (K) - ppm</label>", 
                       unsafe_allow_html=True)
            potassium = st.number_input(
                "Potassium",
                min_value=0,
                max_value=500,
                value=220,
                step=1,
                label_visibility="collapsed",
                key="potassium_input"
            )
            st.markdown(
                "<span class='helper-text'>Available potassium in soil</span>",
                unsafe_allow_html=True
            )
            
            # pH Input
            st.markdown("<label class='input-label'>Soil pH</label>", 
                       unsafe_allow_html=True)
            soil_ph = st.number_input(
                "pH",
                min_value=4.0,
                max_value=9.0,
                value=6.5,
                step=0.1,
                label_visibility="collapsed",
                key="ph_input"
            )
            st.markdown(
                "<span class='helper-text'>Soil acidity/alkalinity level</span>",
                unsafe_allow_html=True
            )
            
            # Organic Matter Input
            st.markdown("<label class='input-label'>Organic Matter (%)</label>", 
                       unsafe_allow_html=True)
            organic_matter = st.number_input(
                "Organic Matter",
                min_value=0.0,
                max_value=10.0,
                value=2.5,
                step=0.1,
                label_visibility="collapsed",
                key="organic_matter_input"
            )
            st.markdown(
                "<span class='helper-text'>Percentage of organic content</span>",
                unsafe_allow_html=True
            )
            
            # Crop Selection
            st.markdown("<label class='input-label'>Select Crop</label>", 
                       unsafe_allow_html=True)
            selected_crop = st.selectbox(
                "Crop",
                available_crops,
                index=0,
                label_visibility="collapsed",
                key="crop_select"
            )
            st.markdown(
                "<span class='helper-text'>Choose your primary crop</span>",
                unsafe_allow_html=True
            )
            
            # Analyze Button
            analyze_button = st.button(
                "🔍 Analyze & Recommend",
                use_container_width=True,
                key="analyze_btn"
            )
    
    # ========================================================================
    # RIGHT COLUMN - RESULT CARD
    # ========================================================================
    
    with col_result:
        # Result container with custom styling
        if 'show_results' not in st.session_state:
            st.session_state.show_results = False
        
        if 'recommendation_data' not in st.session_state:
            st.session_state.recommendation_data = None
        
        # Handle button click
        if analyze_button:
            st.session_state.show_results = True
            
            # Simulate analysis with loading
            with st.spinner("🔬 Analyzing soil composition..."):
                time.sleep(1.5)
            
            # Make prediction using ML model
            fertilizer, confidence = predict_fertilizer(
                nitrogen, phosphorus, potassium, soil_ph, selected_crop,
                model, crop_encoder, fertilizer_encoder, scaler
            )
            
            st.session_state.recommendation_data = {
                'fertilizer': fertilizer,
                'confidence': confidence,
                'n': nitrogen,
                'p': phosphorus,
                'k': potassium,
                'ph': soil_ph,
                'om': organic_matter,
                'crop': selected_crop
            }
            
            # Show success message
            st.success("✅ Analysis completed successfully!")
        
        # Display results or ready state in card
        st.markdown("<div class='result-card'>", unsafe_allow_html=True)
        
        if st.session_state.show_results and st.session_state.recommendation_data:
            data = st.session_state.recommendation_data
            display_recommendation(data['fertilizer'], data['confidence'])
            
            # Display input parameters used
            st.markdown("---")
            
            col_param1, col_param2 = st.columns(2)
            with col_param1:
                st.markdown(
                    f"<p class='param-label'>N (Nitrogen)</p><p class='param-value'>{data['n']} ppm</p>",
                    unsafe_allow_html=True
                )
                st.markdown(
                    f"<p class='param-label'>K (Potassium)</p><p class='param-value'>{data['k']} ppm</p>",
                    unsafe_allow_html=True
                )
            
            with col_param2:
                st.markdown(
                    f"<p class='param-label'>P (Phosphorus)</p><p class='param-value'>{data['p']} ppm</p>",
                    unsafe_allow_html=True
                )
                st.markdown(
                    f"<p class='param-label'>pH</p><p class='param-value'>{data['ph']}</p>",
                    unsafe_allow_html=True
                )
            
            # Reset button
            if st.button("↻ New Analysis", use_container_width=True):
                st.session_state.show_results = False
                st.session_state.recommendation_data = None
                st.rerun()
        
        else:
            display_ready_state()
        
        st.markdown("</div>", unsafe_allow_html=True)
    
    # ========================================================================
    # FOOTER
    # ========================================================================
    
    st.markdown("---")
    
    footer_col1, footer_col2, footer_col3 = st.columns(3)
    
    with footer_col1:
        st.markdown(
            "<p style='text-align: center; color: #9ca3af; font-size: 0.9rem;'>"
            "📍 Agricultural Technology</p>",
            unsafe_allow_html=True
        )
    
    with footer_col2:
        st.markdown(
            "<p style='text-align: center; color: #9ca3af; font-size: 0.9rem;'>"
            "🚀 Powered by ML Pipeline</p>",
            unsafe_allow_html=True
        )
    
    with footer_col3:
        st.markdown(
            "<p style='text-align: center; color: #9ca3af; font-size: 0.9rem;'>"
            "v1.0 - 2026</p>",
            unsafe_allow_html=True
        )


# ============================================================================
# ENTRY POINT
# ============================================================================

if __name__ == "__main__":
    main()
